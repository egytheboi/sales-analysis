
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

# This data is tracking a markets sales
# the column called payment_method tells us how the customer paid
# The column called order_total tells us the total price for a specific order
df = pd.read_csv('finalproject.csv')

print('these are the first five rows')
print(df.head())
print('this is the shape')
print(df.shape)

print('\nThese are the columns we are working with')
print(df.columns)
print('\nDataset Information')
df.info()

print('\nSummary Statistics')
print(df.describe())

print('Dtype info')
print(df.dtypes)

print('\nMissing values in each column:')
print(df.isnull().sum())

print('\nNumber of duplicate rows:')
print(df.duplicated(subset='order_id').sum())

"""we have 4 problems


* missing values in  multiple columns
* multiple duplicates
* date and order_id columns' dtype is wrong
* city formating is inconsistent








"""

df_cleaned = df.drop_duplicates().copy()
df_cleaned['order_date'] = pd.to_datetime(
    df_cleaned['order_date'],
    format='mixed',
    dayfirst=True
)
df_cleaned['order_id'] = df_cleaned['order_id'].astype(str)


# Filling missing values using the median
df_cleaned['order_total'] = df_cleaned['order_total'].fillna(df_cleaned['order_total'].median())
df_cleaned['customer_rating'] = df_cleaned['customer_rating'].fillna(df_cleaned['customer_rating'].median())
df_cleaned['customer_age'] = df_cleaned['customer_age'].fillna(df_cleaned['customer_age'].median())
df_cleaned = df_cleaned.dropna()


# Fixing city column formatting
df_cleaned['city'] = df_cleaned['city'].str.strip().str.capitalize()
df_cleaned['city'] = df_cleaned['city'].replace('Alex', 'Alexandria')

# Fixing product category column formatting
df_cleaned['product_category'] = df_cleaned['product_category'].str.strip().str.capitalize()
print(df_cleaned['product_category'].unique())

# Fixing payment method column formatting
df_cleaned['payment_method'] = df_cleaned['payment_method'].str.strip().str.capitalize()
df_cleaned['payment_method'] = df_cleaned['payment_method'].replace('Wallet', 'Cash')
print(df_cleaned['payment_method'].unique())


print('\nNumber of nans after cleaning:')
print(df_cleaned.isna().sum())
print('\nUnique cities after cleaning:')
print(df_cleaned['city'].unique())



#removing illogical negative values


df_cleaned = df_cleaned[df_cleaned['order_total'] > 0].copy()
Q1_ortotal = df_cleaned['order_total'].quantile(0.25)
Q3_ortotal = df_cleaned['order_total'].quantile(0.75)
IQR_ortotal = Q3_ortotal - Q1_ortotal

lower_bound_ortotal = Q1_ortotal - 1.5 * IQR_ortotal
upper_bound_ortotal = Q3_ortotal + 1.5 * IQR_ortotal



# removing illogical negative values
df_cleaned = df_cleaned[df_cleaned['customer_age'] > 0].copy()
Q1_age = df_cleaned['customer_age'].quantile(0.25)
Q3_age = df_cleaned['customer_age'].quantile(0.75)
IQR_age = Q3_age - Q1_age

lower_bound_age = Q1_age - 1.5 * IQR_age
upper_bound_age = Q3_age + 1.5 * IQR_age


outliers_ortotal = df_cleaned[(df_cleaned['order_total'] < lower_bound_ortotal) | (df_cleaned['order_total'] > upper_bound_ortotal)]


outliers_age = df_cleaned[(df_cleaned['customer_age'] < lower_bound_age) | (df_cleaned['customer_age'] > upper_bound_age)]


#drop illogical ages
df_cleaned = df_cleaned[~df_cleaned.index.isin(outliers_age.index)]




print(f'Lower Bound: {lower_bound_ortotal}')
print(f'Upper Bound: {upper_bound_ortotal}')
print(f'Total outliers found: {len(outliers_ortotal)}')

print(outliers_ortotal)
print(outliers_age)

# outliers here are most likely premium purchases not errors

